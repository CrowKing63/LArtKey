<Application x:Class="LAltKey.Tools.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- text. -->
                <ResourceDictionary Source="/LAltKey;component/Themes/Generic.xaml"/>
                <!-- text. -->
                <ResourceDictionary Source="/LAltKey;component/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/LAltKey;component/Themes/SettingsControls.xaml"/>
                <!-- Phase 1: text -->
                <ResourceDictionary Source="/LAltKey;component/Themes/FluentControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- text. -->
            <FontFamily x:Key="AppFontFamily">NanumGothic, Malgun Gothic, Segoe UI</FontFamily>
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            </Style>
            <Style TargetType="Window">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
