<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- text. -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <!-- text. -->
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <!-- text. -->
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="TextElement.Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <!-- text. -->
                <Setter Property="Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="RowBackground" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource SettingsBorder}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
