<UserControl x:Class="LAltKey.Views.ClipboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LAltKey.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ClipboardViewModel}">

    <Border Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource PanelBorder}"
            BorderThickness="0,0,0,1"
            CornerRadius="0,0,8,8"
            Padding="4"
            VerticalAlignment="Top">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- text -->
                <RowDefinition Height="*"/>     <!-- text -->
            </Grid.RowDefinitions>

            <!-- text -->
            <Grid Grid.Row="0" Margin="4,4,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- text -->
                    <ColumnDefinition Width="Auto"/> <!-- text -->
                </Grid.ColumnDefinitions>

                <!-- text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- "text" text -->
                    <Button Content="Recent"
                            Command="{Binding SwitchToHistoryTabCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource PanelFg}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavoritesTab}" Value="False">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- "text" text -->
                    <Button Content="Favorites"
                            Command="{Binding SwitchToFavoritesTabCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource PanelFg}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavoritesTab}" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- text -->
                <Button Content="✕"
                        Grid.Column="1"
                        Command="{Binding CloseCommand}"
                        Width="20" Height="20"
                        Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource PanelFg}"
                        Opacity="0.6" Cursor="Hand"
                        FontSize="11" Padding="0"/>
            </Grid>

            <!-- text -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ClipboardItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>    <!-- text -->
                                    <ColumnDefinition Width="Auto"/> <!-- ★ text -->
                                </Grid.ColumnDefinitions>

                                <!-- text) -->
                                <Button Grid.Column="0"
                                        Command="{Binding DataContext.PasteItemCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding FullText}"
                                        HorizontalContentAlignment="Left"
                                        BorderThickness="0"
                                        Padding="6,4"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PanelFg}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource KeyBgHover}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Preview}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PanelFg}"/>
                                </Button>

                                <!-- text (★) -->
                                <Button Grid.Column="1"
                                        Command="{Binding DataContext.ToggleFavoriteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding FullText}"
                                        Width="20" Height="20"
                                        Padding="0"
                                        Margin="2,0,4,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.3"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToStar}}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PanelFg}"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
