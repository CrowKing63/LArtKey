<Window x:Class="LAltKey.Views.FocusA11ySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LAltKey.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Focus visibility settings"
        Width="560" Height="460"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Window.Resources>
        <!-- text. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
    </Window.Resources>

    <Border Background="{DynamicResource SettingsBg}"
            CornerRadius="12"
            Padding="20">
        <StackPanel>
            <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Focus visibility settings"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SettingsFg}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Adjust keyboard navigation behavior and focus announcements."
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,4"
                               Text="Accessibility settings for navigating screen elements and announcing the current position."/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,12"
                               Text="Works with Tab, Shift+Tab, Enter, and Space."/>

                    <TextBlock Text="Navigation scope" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding KeyboardA11yNavigationScopes}"
                              SelectedItem="{Binding KeyboardA11yNavigationScope}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="Navigation exit key (VK name)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding KeyboardA11yExitKey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Live region announcements" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                    <CheckBox Content="Announce current focus when it moves"
                              Foreground="{DynamicResource SettingsFg}"
                              IsChecked="{Binding KeyboardA11yAnnounceFocus}"/>
                </StackPanel>
            </Border>

            <Button Content="Close"
                    Height="34"
                    HorizontalAlignment="Right"
                    Width="110"
                    Click="CloseButton_Click"
                    Background="{DynamicResource SettingsHighlight}"
                    Foreground="{DynamicResource SettingsFg}"
                    BorderThickness="0"
                    Cursor="Hand"
                    AutomationProperties.Name="Close focus visibility settings"/>
        </StackPanel>
    </Border>
</Window>
