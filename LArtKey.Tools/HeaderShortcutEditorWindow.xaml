<Window x:Class="LArtKey.Tools.HeaderShortcutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LArtKey.Views;assembly=LArtKey"
        Title="Header shortcut editor"
        Width="820"
        Height="760"
        MinWidth="700"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SettingsBg}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="Header shortcut editor window">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="{DynamicResource SettingsBg}"
            BorderBrush="{DynamicResource SettingsBorder}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="{Binding WindowTitle}"
                           AutomationProperties.Name="Header shortcut editor title"/>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Edit an icon-only header button. Clear tooltips and accessible names improve usability."
                               TextWrapping="Wrap"
                               AutomationProperties.Name="Header shortcut editor instructions"/>
                    <TextBlock Text="Set the action type and parameters in the action builder below."
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource SettingsFgSub}"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="Header shortcut action instructions"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Button details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                                <TextBlock Text="Header icon text" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="IconTextBox"
                                         Text="{Binding IconText, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Header icon text input"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock Text="Placement" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Positions}"
                                          SelectedItem="{Binding SelectedPosition}"
                                          AutomationProperties.Name="Header placement selector"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                <TextBlock Text="Tooltip text" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TooltipText, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Header tooltip input"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Screen reader name" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AccessibleNameText, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Header screen reader name input"/>
                            </StackPanel>

                            <CheckBox Grid.Row="3" Grid.Column="1"
                                      Content="Show in header"
                                      IsChecked="{Binding IsHeaderButtonVisible}"
                                      VerticalAlignment="Center"
                                      AutomationProperties.Name="Header visibility"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource FluentCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Action" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <views:ActionBuilderView DataContext="{Binding ActionBuilder}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="Save"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnSave"
                        AutomationProperties.Name="Save header shortcut button"/>
                <Button Content="Close (Esc)"
                        Width="120"
                        Height="34"
                        Click="OnClose"
                        AutomationProperties.Name="Close header shortcut button"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
