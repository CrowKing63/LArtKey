<Window x:Class="LArtKey.Tools.AiPromptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI English text"
        Width="760"
        Height="520"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SettingsBg}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="AI English text">
    <Window.Resources>
        <!-- English text. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="{DynamicResource SettingsBg}"
            BorderBrush="{DynamicResource SettingsBorder}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <TextBlock Margin="0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="AI English text"
                           AutomationProperties.Name="AI English text"/>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="English text."
                               TextWrapping="Wrap"
                               AutomationProperties.Name="AI English text"/>
                    <TextBlock Text="English text."
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource SettingsFgSub}"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="AI English text"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource FluentCardBorderStyle}">
                <TextBox x:Name="PromptTextBox"
                         Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextWrapping="Wrap"
                         Padding="12,10"
                         FontSize="14"
                         KeyboardNavigation.TabIndex="0"
                         AutomationProperties.Name="AI English text"/>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="English text"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        KeyboardNavigation.TabIndex="1"
                        Click="OnSave"
                        AutomationProperties.Name="AI English text"/>
                <Button Content="English text (Esc)"
                        Width="120"
                        Height="34"
                        KeyboardNavigation.TabIndex="2"
                        Click="OnClose"
                        AutomationProperties.Name="AI English text"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
