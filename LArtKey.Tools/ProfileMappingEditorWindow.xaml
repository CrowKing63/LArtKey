<Window x:Class="LArtKey.Tools.ProfileMappingEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="English text"
        Width="860"
        Height="560"
        MinWidth="720"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SettingsBg}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="English text">
    <Window.Resources>
        <!-- English text. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
        <Style TargetType="DataGrid" BasedOn="{StaticResource FluentDataGridStyle}"/>
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="{DynamicResource SettingsBg}"
            BorderBrush="{DynamicResource SettingsBorder}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="English text"
                           AutomationProperties.Name="English text"/>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="English text."
                               TextWrapping="Wrap"
                               AutomationProperties.Name="English text"/>
                    <TextBlock Text="{Binding ValidationSummaryText}"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource SettingsFgSub}"
                               AutomationProperties.Name="English text"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource FluentCardBorderStyle}">
                <DataGrid x:Name="ProfileGrid"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          RowBackground="{DynamicResource SettingsBg}"
                          AlternatingRowBackground="{DynamicResource SettingsHighlight}"
                          HorizontalGridLinesBrush="{DynamicResource SettingsBorder}"
                          VerticalGridLinesBrush="{DynamicResource SettingsBorder}"
                          BorderBrush="{DynamicResource SettingsBorder}"
                          KeyboardNavigation.TabIndex="0"
                          AutomationProperties.Name="English text">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="English text"
                                            Binding="{Binding ProcessName, UpdateSourceTrigger=LostFocus}"
                                            Width="2*" />
                        <DataGridComboBoxColumn Header="English text"
                                                SelectedItemBinding="{Binding LayoutName, UpdateSourceTrigger=LostFocus}"
                                                ItemsSource="{Binding DataContext.AvailableLayouts, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Width="2*" />
                        <DataGridTextColumn Header="English text"
                                            Binding="{Binding Status}"
                                            IsReadOnly="True"
                                            Width="*" />
                        <DataGridTemplateColumn Header="English text" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="English text"
                                            Padding="8,4"
                                            Margin="4,0,0,0"
                                            Click="OnRemoveRow"
                                            Tag="{Binding}"
                                            AutomationProperties.Name="English text"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="+ English text"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        KeyboardNavigation.TabIndex="1"
                        Click="OnAddRow"
                        AutomationProperties.Name="English text"/>
                <Button Content="English text"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        KeyboardNavigation.TabIndex="2"
                        Click="OnSave"
                        AutomationProperties.Name="English text"/>
                <Button Content="English text (Esc)"
                        Width="120"
                        Height="34"
                        KeyboardNavigation.TabIndex="3"
                        Click="OnClose"
                        AutomationProperties.Name="English text"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
