<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- English text. -->
    <Thickness x:Key="FluentContentPadding">12,8</Thickness>
    <Thickness x:Key="FluentSectionSpacing">0,0,0,12</Thickness>
    <CornerRadius x:Key="FluentCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="FluentLargeCornerRadius">12</CornerRadius>

    <Style x:Key="FluentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="{StaticResource FluentContentPadding}"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource SettingsFg}"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource SettingsFgHint}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
                <Setter Property="Opacity" Value="0.72"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource SettingsFgHint}"/>
                <Setter Property="Opacity" Value="0.82"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
                <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <!-- English text. -->
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="TextElement.Foreground" Value="Black"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- English text. -->
    <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="TextElement.Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource FluentComboBoxItemStyle}"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource SettingsFgHint}"/>
                <Setter Property="Opacity" Value="0.82"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
        <Setter Property="Padding" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="FluentDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="RowHeight" Value="32"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
    </Style>

    <Style x:Key="FluentCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerRadius}"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style x:Key="FluentSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource SettingsHighlight}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="2,0"/>
        <Style.Triggers>
            <!-- English text. -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonDisabledFg}"/>
                <Setter Property="Opacity" Value="{DynamicResource SecondaryButtonDisabledOpacity}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

    <Style x:Key="FluentDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource ElevatedWarningBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource ElevatedWarningFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ElevatedWarningBg}"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="2,0"/>
    </Style>

    <Style x:Key="FluentEditorInputBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SettingsBorder}"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style x:Key="FluentLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SettingsFg}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>
</ResourceDictionary>
