<UserControl x:Class="LArtKey.Views.KeyboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LArtKey.ViewModels"
             xmlns:controls="clr-namespace:LArtKey.Controls"
             xmlns:views="clr-namespace:LArtKey.Views"
             mc:Ignorable="d"
             Focusable="False"
             d:DesignWidth="900" d:DesignHeight="320">

    <UserControl.Resources>
        <!-- English text. -->
        <Style x:Key="HeaderBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- English text. -->
        <Style x:Key="HeaderBarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- English text. -->
        <Style x:Key="HeaderCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0,16,16,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBarPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- English text -->
        <!-- English text. -->
        <Border Background="{DynamicResource KeyboardBg}"
                CornerRadius="{StaticResource KeyboardRadius}"
                ClipToBounds="True">

        <!-- English text → English text) -->
        <DockPanel LastChildFill="True">

            <!-- English text -->
            <!-- English text. -->
            <Border DockPanel.Dock="Top"
                    Background="Transparent"
                    CornerRadius="16,16,0,0">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- English text) -->
                <Border Grid.Column="0"
                        Margin="12,0,8,0"
                        ClipToBounds="True"
                        Background="Transparent"
                        MouseLeftButtonDown="HeaderBlankArea_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="LArtKey" Foreground="{DynamicResource TitleFg}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <!-- English text -->
                    <Button Width="14" Height="14" Margin="5,0,0,1"
                            Style="{StaticResource HeaderBarButtonStyle}"
                            Cursor="Hand" IsHitTestVisible="True"
                            Command="{Binding DownloadAndInstallUpdateCommand}"
                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding UpdateIndicatorTooltip}">
                        <Grid>
                            <!-- English text -->
                            <Ellipse Width="8" Height="8" Fill="#FFF97316"
                                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                            <!-- English text -->
                            <Ellipse Width="8" Height="8" Fill="#FF2563EB"
                                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Button>

                    <!-- English text -->
                    <ItemsControl ItemsSource="{Binding HeaderButtonsLeft}"
                                  Margin="8,0,0,0" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- IsToggleEnglish text -->
                                <Grid>
                                    <!-- English text (IsToggle=falseEnglish text) -->
                                    <Button Width="{Binding Width}" Height="28"
                                            Style="{StaticResource HeaderBarButtonStyle}"
                                            Foreground="{DynamicResource TitleFg}"
                                            BorderThickness="0" Cursor="Hand" Focusable="False"
                                            Command="{Binding Command}"
                                            ToolTip="{Binding ToolTip}"
                                            AutomationProperties.Name="{Binding AccessibleName}"
                                            AutomationProperties.HelpText="{Binding AccessibleHelp}"
                                            Visibility="{Binding IsToggle, Converter={StaticResource InvBoolToVis}}">
                                        <TextBlock Text="{Binding Icon}" FontSize="{Binding FontSize}"/>
                                    </Button>
                                    <!-- English text, IsToggle=trueEnglish text) -->
                                    <ToggleButton Width="{Binding Width}" Height="28"
                                                  Style="{StaticResource HeaderBarToggleButtonStyle}"
                                                  Foreground="{DynamicResource TitleFg}"
                                                  BorderThickness="0" Cursor="Hand" Focusable="False"
                                                  IsChecked="{Binding DataContext.AutoCompleteEnabled, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  IsEnabled="{Binding DataContext.CanToggleAutoComplete, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  ToolTip="{Binding ToolTip}"
                                                  AutomationProperties.Name="{Binding AccessibleName}"
                                                  AutomationProperties.HelpText="{Binding AccessibleHelp}"
                                                  Visibility="{Binding IsToggle, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding Icon}" FontSize="{Binding FontSize}"/>
                                    </ToggleButton>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </Border>

                <!-- English text -->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Panel.ZIndex="1">
                    <Button Width="18" Height="18" Content="&#x2190;" ToolTip="English text"
                            Style="{StaticResource HeaderBarButtonStyle}"
                            Foreground="{DynamicResource TitleFg}" Opacity="0.78"
                            Cursor="Hand" Padding="0" FontSize="10"
                            Click="EdgeLeftBtn_Click"
                            AutomationProperties.Name="English text"/>
                    <Button Width="18" Height="18" Content="&#x2191;" ToolTip="English text"
                            Style="{StaticResource HeaderBarButtonStyle}"
                            Foreground="{DynamicResource TitleFg}" Opacity="0.78"
                            Cursor="Hand" Padding="0" FontSize="10"
                            Click="EdgeUpBtn_Click"
                            AutomationProperties.Name="English text"/>

                    <!-- English text (DragPill) -->
                    <Border x:Name="DragHandle"
                            Background="Transparent"
                            Cursor="SizeAll"
                            Margin="2,0" Padding="4,12"
                            MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"
                            MouseMove="DragHandle_MouseMove"
                            MouseLeftButtonUp="DragHandle_MouseLeftButtonUp"
                            LostMouseCapture="DragHandle_LostMouseCapture"
                            MouseEnter="DragHandle_MouseEnter"
                            MouseLeave="DragHandle_MouseLeave">
                        <Rectangle x:Name="DragPill"
                                   Width="36" Height="4"
                                   Fill="{DynamicResource TitleFg}"
                                   Opacity="0.45"
                                   RadiusX="2" RadiusY="2"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Border>

                    <Button Width="18" Height="18" Content="&#x2193;" ToolTip="English text"
                            Style="{StaticResource HeaderBarButtonStyle}"
                            Foreground="{DynamicResource TitleFg}" Opacity="0.78"
                            Cursor="Hand" Padding="0" FontSize="10"
                            Click="EdgeDownBtn_Click"
                            AutomationProperties.Name="English text"/>
                    <Button Width="18" Height="18" Content="&#x2192;" ToolTip="English text"
                            Style="{StaticResource HeaderBarButtonStyle}"
                            Foreground="{DynamicResource TitleFg}" Opacity="0.78"
                            Cursor="Hand" Padding="0" FontSize="10"
                            Click="EdgeRightBtn_Click"
                            AutomationProperties.Name="English text"/>
                </StackPanel>

                <!-- English text -->
                <Border Grid.Column="2"
                        Margin="8,0,0,0"
                        ClipToBounds="True"
                        Background="Transparent"
                        MouseLeftButtonDown="HeaderBlankArea_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <!-- English text (ItemsControl) -->
                    <ItemsControl ItemsSource="{Binding HeaderButtonsRight}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- IsToggleEnglish text -->
                                <Grid>
                                    <!-- English text (IsToggle=falseEnglish text) -->
                                    <Button Width="{Binding Width}" Height="28"
                                            Style="{StaticResource HeaderBarButtonStyle}"
                                            Foreground="{DynamicResource TitleFg}"
                                            BorderThickness="0" Cursor="Hand" Focusable="False"
                                            Command="{Binding Command}"
                                            ToolTip="{Binding ToolTip}"
                                            AutomationProperties.Name="{Binding AccessibleName}"
                                            AutomationProperties.HelpText="{Binding AccessibleHelp}"
                                            Visibility="{Binding IsToggle, Converter={StaticResource InvBoolToVis}}">
                                        <TextBlock Text="{Binding Icon}" FontSize="{Binding FontSize}"/>
                                    </Button>
                                    <!-- English text, IsToggle=trueEnglish text) -->
                                    <ToggleButton Width="{Binding Width}" Height="28"
                                                  Style="{StaticResource HeaderBarToggleButtonStyle}"
                                                  Foreground="{DynamicResource TitleFg}"
                                                  BorderThickness="0" Cursor="Hand" Focusable="False"
                                                  IsChecked="{Binding DataContext.AutoCompleteEnabled, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  IsEnabled="{Binding DataContext.CanToggleAutoComplete, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  ToolTip="{Binding ToolTip}"
                                                  AutomationProperties.Name="{Binding AccessibleName}"
                                                  AutomationProperties.HelpText="{Binding AccessibleHelp}"
                                                  Visibility="{Binding IsToggle, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding Icon}" FontWeight="Bold" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- English text. -->
                    <Button x:Name="CollapseButton" Width="32" Height="28"
                            Style="{StaticResource HeaderBarButtonStyle}" Foreground="{DynamicResource TitleFg}"
                            BorderThickness="0" Cursor="Hand" Focusable="False"
                            Click="CollapseButton_Click"
                            ToolTip="English text"
                            AutomationProperties.Name="English text">
                        <TextBlock x:Name="CollapseIcon" Text="&#x25B2;" FontSize="10"/>
                    </Button>
                    <Button x:Name="CloseButton" Width="32" Height="28"
                            Style="{StaticResource HeaderCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="English text)"
                            AutomationProperties.Name="English text">
                        <TextBlock Text="&#x2715;" FontSize="14"/>
                    </Button>
                </StackPanel>
                </Border>
            </Grid>
            </Border>

            <!-- T-9.3: English text) -->
            <views:SuggestionBar
                x:Name="AutoCompleteBar"
                DockPanel.Dock="Top"
                DataContext="{Binding AutoComplete}"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                Height="{Binding DataContext.Keyboard.SuggestionBarHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <!-- 08: LiveRegion English text) -->
            <TextBlock x:Name="ModeAnnouncer"
                       Text="{Binding Keyboard.ModeAnnouncement}"
                       Opacity="0"
                       IsHitTestVisible="False"
                       AutomationProperties.LiveSetting="Polite"
                       Width="0" Height="0"/>

            <!-- T-2.10: UAC English text) -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource ElevatedWarningBg}" CornerRadius="4"
                    Padding="12,6"
                    Visibility="{Binding Keyboard.ShowElevatedWarning, Converter={StaticResource BoolToVis}}">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ElevatedWarningFg}"
                           Text="English text."/>
            </Border>

            <!-- T-3.7 / T-4.10: English text) -->
            <Border x:Name="KeyboardBorder"
                    Background="Transparent"
                    CornerRadius="0" Padding="6,4"
                    SizeChanged="KeyboardBorder_SizeChanged"
                    MouseLeftButtonDown="KeyboardBorder_MouseLeftButtonDown">
                <ItemsControl ItemsSource="{Binding Keyboard.Columns}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:KeyColumnVm}">
                            <StackPanel Orientation="Vertical"
                                        Margin="{Binding Gap, Converter={StaticResource GapToRightMargin}}">
                                <ItemsControl ItemsSource="{Binding Rows}"
                                              HorizontalAlignment="Center">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:KeyRowVm}">
                                            <ItemsControl ItemsSource="{Binding Keys}"
                                                          HorizontalAlignment="Center"
                                                          MinHeight="{Binding PixelHeight}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:KeySlotVm}">
                                                  <controls:KeyButton
                                                      Slot="{Binding}"
                                                      ShowUpperCase="{Binding DataContext.Keyboard.ShowUpperCase,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DisplayLabel="{Binding DisplayLabel}"
                                                      SubLabel="{Binding SubLabelText}"
                                                      IsDimmed="{Binding IsDimmed}"
                                                      IsSticky="{Binding IsSticky}"
                                                      IsLocked="{Binding IsLocked}"
                                                      IsFunctionOneShot="{Binding IsFunctionOneShot}"
                                                      IsFunctionLocked="{Binding IsFunctionLocked}"
                                                      HasFunctionLayerAccent="{Binding HasFunctionLayerAccent}"
                                                      IsA11yFocused="{Binding IsA11yFocused}"
                                                      KeyUnit="{Binding DataContext.Keyboard.KeyUnit,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DwellEnabled="{Binding DataContext.DwellEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DwellTime="{Binding DataContext.DwellTimeMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatEnabled="{Binding DataContext.KeyRepeatEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatDelayMs="{Binding DataContext.KeyRepeatDelayMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyRepeatIntervalMs="{Binding DataContext.KeyRepeatIntervalMs,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      KeyboardA11yNavigationEnabled="{Binding DataContext.KeyboardA11yNavigationEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      ReducedMotionEnabled="{Binding DataContext.ReducedMotionEnabled,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      TtsOnHover="{Binding DataContext.TtsOnHover,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      Command="{Binding DataContext.Keyboard.KeyPressedCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding Slot}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Border>

        </DockPanel>
        </Border>

        <!-- T-8.3: English text) -->
        <views:EmojiPanel
            DataContext="{Binding Emoji}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Top"
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        <!-- T-8.4: English text) -->
        <views:ClipboardPanel
            DataContext="{Binding Clipboard}"
            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            
            Margin="0,28,0,0"
            Panel.ZIndex="6"/>

        </Grid>
</UserControl>
