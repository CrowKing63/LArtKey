<Window x:Class="LArtKey.Views.SwitchScanSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LArtKey.ViewModels"
        xmlns:ctrl="clr-namespace:LArtKey.Controls"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="English text"
        Width="680" Height="820"
        MinWidth="600" MinHeight="700"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">
    <Window.Resources>
        <!-- English text. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
    </Window.Resources>

    <Border Background="{DynamicResource SettingsBg}"
            CornerRadius="12"
            Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="English text"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SettingsFg}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="English text."
                                   FontSize="11"
                                   Foreground="{DynamicResource SettingsFgSub}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBlock Text="English text)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ctrl:NumericAdjuster Value="{Binding SwitchScanIntervalMs}"
                                              Minimum="200" Maximum="3000" Step="100" DecimalPlaces="0"
                                              IsEnabled="{Binding SwitchScanEnabled}"
                                              ButtonBackground="{DynamicResource SettingsHighlight}"
                                              ButtonForeground="{DynamicResource SettingsFg}"
                                              TextBoxBackground="{DynamicResource SettingsHighlight}"
                                              TextBoxForeground="{DynamicResource SettingsFg}"
                                              TextBoxBorderBrush="{DynamicResource SettingsBorder}"
                                              Margin="0,0,0,8"/>
                        <CheckBox Content="2English text)"
                                  Foreground="{DynamicResource SettingsFg}"
                                  IsChecked="{Binding SwitchScanTwoSwitch}"
                                  IsEnabled="{Binding SwitchScanEnabled}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SwitchScanModes}"
                                  SelectedItem="{Binding SwitchScanMode}"
                                  IsEnabled="{Binding SwitchScanEnabled}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="English text)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ctrl:NumericAdjuster Value="{Binding SwitchScanInitialDelayMs}" Minimum="0" Maximum="5000" Step="100" DecimalPlaces="0"
                                              IsEnabled="{Binding SwitchScanEnabled}"
                                              ButtonBackground="{DynamicResource SettingsHighlight}" ButtonForeground="{DynamicResource SettingsFg}"
                                              TextBoxBackground="{DynamicResource SettingsHighlight}" TextBoxForeground="{DynamicResource SettingsFg}"
                                              TextBoxBorderBrush="{DynamicResource SettingsBorder}" Margin="0,0,0,8"/>
                        <TextBlock Text="English text)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ctrl:NumericAdjuster Value="{Binding SwitchScanSelectPauseMs}" Minimum="0" Maximum="5000" Step="100" DecimalPlaces="0"
                                              IsEnabled="{Binding SwitchScanEnabled}"
                                              ButtonBackground="{DynamicResource SettingsHighlight}" ButtonForeground="{DynamicResource SettingsFg}"
                                              TextBoxBackground="{DynamicResource SettingsHighlight}" TextBoxForeground="{DynamicResource SettingsFg}"
                                              TextBoxBorderBrush="{DynamicResource SettingsBorder}" Margin="0,0,0,8"/>
                        <TextBlock Text="English text (0=English text)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ctrl:NumericAdjuster Value="{Binding SwitchScanCyclesBeforePause}" Minimum="0" Maximum="20" Step="1" DecimalPlaces="0"
                                              IsEnabled="{Binding SwitchScanEnabled}"
                                              ButtonBackground="{DynamicResource SettingsHighlight}" ButtonForeground="{DynamicResource SettingsFg}"
                                              TextBoxBackground="{DynamicResource SettingsHighlight}" TextBoxForeground="{DynamicResource SettingsFg}"
                                              TextBoxBorderBrush="{DynamicResource SettingsBorder}" Margin="0,0,0,8"/>
                        <CheckBox Content="English text"
                                  Foreground="{DynamicResource SettingsFg}"
                                  IsChecked="{Binding SwitchScanWrapEnabled}"
                                  IsEnabled="{Binding SwitchScanEnabled}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="English text"
                                  Foreground="{DynamicResource SettingsFg}"
                                  IsChecked="{Binding SwitchScanIncludeSuggestions}"
                                  IsEnabled="{Binding SwitchScanEnabled}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding SwitchScanSuggestionPriorities}"
                                  SelectedItem="{Binding SwitchScanSuggestionPriority}"
                                  IsEnabled="{Binding SwitchScanEnabled}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="English text (VK_English text)" Foreground="{DynamicResource SettingsFgSub}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding SwitchScanNextKey, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SwitchScanEnabled}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SwitchScanSelectKey, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SwitchScanEnabled}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SwitchScanSecondarySelectKey, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SwitchScanEnabled}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SwitchScanPreviousKey, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SwitchScanEnabled}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SwitchScanPauseKey, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SwitchScanEnabled}" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource SettingsFgSub}"
                                   Text="English text: VK_TAB / VK_RETURN / VK_SPACE"/>
                    </StackPanel>
                </Border>

                <Button Content="English text"
                        Height="34"
                        HorizontalAlignment="Right"
                        Width="110"
                        Click="CloseButton_Click"
                        Background="{DynamicResource SettingsHighlight}"
                        Foreground="{DynamicResource SettingsFg}"
                        BorderThickness="0"
                        Cursor="Hand"
                        AutomationProperties.Name="English text"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
