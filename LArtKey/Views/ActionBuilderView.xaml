<UserControl x:Class="LArtKey.Views.ActionBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:LArtKey.ViewModels"
             xmlns:ctrl="clr-namespace:LArtKey.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ActionBuilderViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- text. -->
        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource FluentEditorInputBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <!-- text. -->
        <Style x:Key="InputCombo" TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Height" Value="26"/>
            <Style.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="CaretBrush" Value="Black"/>
                    <Setter Property="Background" Value="{DynamicResource SettingsBg}"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SettingsFgSub}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ActionMiniButtonStyle" TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}">
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style TargetType="{x:Type ctrl:NumericAdjuster}">
            <Setter Property="ButtonBackground" Value="{DynamicResource SettingsHighlight}"/>
            <Setter Property="ButtonForeground" Value="{DynamicResource SettingsFg}"/>
            <Setter Property="TextBoxBackground" Value="{DynamicResource SettingsBg}"/>
            <Setter Property="TextBoxForeground" Value="{DynamicResource SettingsFg}"/>
            <Setter Property="TextBoxBorderBrush" Value="{DynamicResource SettingsBorder}"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Action type" Style="{StaticResource HintText}"/>
        <ComboBox ItemsSource="{Binding ActionTypes}"
                  SelectedItem="{Binding SelectedActionType}"
                  Style="{StaticResource InputCombo}"/>

        <StackPanel Visibility="{Binding IsSendKey, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Virtual key code (for example: VK_A, Ctrl+A, A)" Style="{StaticResource HintText}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding CommonVkCodesDisplay}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="VkCode"
                          SelectedValue="{Binding SendKeyVk}"
                          Width="120" Margin="0,0,6,0"
                          IsEditable="True"
                          Style="{StaticResource InputCombo}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SendKeyVk, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputBox}"/>
            </Grid>
        </StackPanel>

        <StackPanel Visibility="{Binding IsSendCombo, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Key combination (for example: Ctrl+A, Shift+B)" Style="{StaticResource HintText}"/>
            <ItemsControl ItemsSource="{Binding SendComboKeysCollection}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding DataContext.CommonVkCodesDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="VkCode"
                                      SelectedValue="{Binding Path=Value, Mode=TwoWay}"
                                      IsEditable="True"
                                      Margin="0,0,4,0"
                                      Style="{StaticResource InputCombo}"/>
                            <Button Grid.Column="1"
                                    Content="&#x00D7;"
                                    Style="{StaticResource ActionMiniButtonStyle}"
                                    Command="{Binding DataContext.RemoveComboKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ Add key"
                    Style="{StaticResource ActionMiniButtonStyle}"
                    Padding="6,4"
                    Command="{Binding AddComboKeyCommand}"
                    HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsToggleSticky, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Modifier key (for example: VK_SHIFT, Shift, Ctrl)" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding CommonVkCodesDisplay}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="VkCode"
                      SelectedValue="{Binding ToggleStickyVk}"
                      IsEditable="True"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsSwitchLayout, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Layout file name (without extension)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding SwitchLayoutName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsRunApp, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Executable path" Style="{StaticResource HintText}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding AppPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0"
                         Style="{StaticResource InputBox}"/>
                <Button Content="Browse"
                        Grid.Column="1" Margin="4,0,0,0"
                        Style="{StaticResource ActionMiniButtonStyle}"
                        Padding="6,4"
                        Command="{Binding BrowseAppCommand}"/>
            </Grid>
            <TextBlock Text="Arguments (optional)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding AppArgs, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsBoilerplate, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Text to type" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding BoilerplateText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsShellCommand, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Command (for example: shutdown /s /t 300)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding ShellCmd, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBox}"/>
            <TextBlock Text="Shell type" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding ShellTypes}"
                      SelectedItem="{Binding SelectedShell}"
                      Style="{StaticResource InputCombo}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsVolumeControl, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Direction (up / down / mute)" Style="{StaticResource HintText}"/>
            <ComboBox ItemsSource="{Binding VolumeDirections}"
                      SelectedItem="{Binding VolumeDirection}"
                      Style="{StaticResource InputCombo}"/>
            <TextBlock Text="Step" Style="{StaticResource HintText}"/>
            <ctrl:NumericAdjuster Value="{Binding VolumeStep}"
                                  Minimum="2" Maximum="20" Step="1" DecimalPlaces="0"
                                  Margin="0,0,0,6"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsClipboardPaste, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Text to paste" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding ClipboardText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsToggleInputMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Input mode toggle key (no parameter)" Style="{StaticResource HintText}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsToggleFunctionLayer, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Fn layer toggle key (once: one-shot, twice: lock, three times: off)" Style="{StaticResource HintText}"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsAi, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="AI prompt (leave empty to use the default prompt from settings)" Style="{StaticResource HintText}"/>
            <TextBox Text="{Binding AiPrompt, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="72" TextWrapping="Wrap"
                     Style="{StaticResource InputBox}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
