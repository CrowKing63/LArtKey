<Window x:Class="LArtKey.Views.CloseToTrayConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Confirm hiding LArtKey"
        Width="430"
        Height="360"
        MinWidth="400"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource SettingsBg}">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
    </Window.Resources>

    <Border Background="{DynamicResource SettingsBg}"
            CornerRadius="12"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Hide the keyboard window to the tray?"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SettingsFg}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="When using full-screen apps, it may be harder to bring the window back after it disappears."
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource SettingsFgSub}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,16,0,16"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                <StackPanel>
                    <TextBlock Text="How to show it again"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SettingsFg}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="• Double-click the tray icon"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Use Show/Hide in the tray menu"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Use the global hotkey"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Run LArtKey again to restore the existing window"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource SettingsFgSub}"
                               Margin="0,0,0,12"/>

                    <CheckBox x:Name="DontAskAgainCheckBox"
                              Content="Do not ask again"
                              Foreground="{DynamicResource SettingsFg}"
                              AutomationProperties.Name="Do not ask again"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButtonElement"
                        Grid.Column="1"
                        Content="Cancel"
                        Width="110"
                        Height="36"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        IsDefault="True"
                        Click="CancelButton_Click"
                        AutomationProperties.Name="Cancel tray hide"/>
                <Button Grid.Column="2"
                        Content="Hide to tray"
                        Width="130"
                        Height="36"
                        Click="HideToTrayButton_Click"
                        Background="{DynamicResource SettingsHighlight}"
                        Foreground="{DynamicResource SettingsFg}"
                        AutomationProperties.Name="Hide to tray"/>
            </Grid>
        </Grid>
    </Border>
</Window>
