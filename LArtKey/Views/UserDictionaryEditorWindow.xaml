<Window x:Class="LArtKey.Views.UserDictionaryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:LArtKey.ViewModels"
        mc:Ignorable="d"
        Title="English text"
        Width="800" Height="600"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="Manual"
        Background="{DynamicResource SettingsBg}"
        d:DataContext="{d:DesignInstance vm:UserDictionaryEditorViewModel}">

    <Window.Resources>
        <!-- English text. -->
        <Style TargetType="Button" BasedOn="{StaticResource FluentButtonStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}"/>
        <Style TargetType="DataGrid" BasedOn="{StaticResource FluentDataGridStyle}"/>

        <!-- English text. -->
        <Style x:Key="DarkBtn" TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}"/>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource FluentPrimaryButtonStyle}"/>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource FluentDangerButtonStyle}"/>
        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource FluentEditorInputBoxStyle}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── English text ── -->
        <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="16,10">
            <Grid>
                <TextBlock Text="English text"
                           Foreground="{DynamicResource SettingsFg}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Content="✕" FontSize="14"
                        Background="Transparent" Foreground="{DynamicResource SettingsFgSub}"
                        BorderThickness="0" Cursor="Hand" Padding="8,2"
                        Click="CloseButton_Click"
                        ToolTip="English text (Esc)"
                        AutomationProperties.Name="English text"/>
            </Grid>
        </Border>

        <!-- ── English text ── -->
        <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="English text"
                             Foreground="{DynamicResource SettingsFg}"
                             IsChecked="{Binding IsWordTabSelected, Mode=TwoWay}"
                             Margin="0,0,12,0" Padding="6,3"
                             GroupName="MainTab"/>
                <RadioButton Content="English text"
                             Foreground="{DynamicResource SettingsFg}"
                             IsChecked="{Binding IsBigramTabSelected, Mode=TwoWay}"
                             Padding="6,3"
                             GroupName="MainTab"/>
            </StackPanel>
        </Border>

        <!-- ── English text ── -->
        <Grid Grid.Row="2" Visibility="{Binding WordTabVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- English text -->
            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="English text"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsPrimaryTabActive, Mode=TwoWay}"
                                 Margin="0,0,12,0" Padding="6,3"
                                 GroupName="DictTab"/>
                    <RadioButton Content="English text"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsEnglishTabActive, Mode=TwoWay}"
                                 Padding="6,3"
                                 GroupName="DictTab"/>
                </StackPanel>
            </Border>

            <!-- English text -->
            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- English text. -->
                    <WrapPanel Grid.Column="0" VerticalAlignment="Center" ItemHeight="28">
                        <TextBlock Text="English text:" Foreground="{DynamicResource SettingsFgSub}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                                 Style="{StaticResource InputBox}"
                                 Width="190" Height="26" Margin="0,0,10,0"
                                 AutomationProperties.Name="English text"/>
                        <TextBlock Text="English text:" Foreground="{DynamicResource SettingsFgSub}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding NewWord, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Width="150" Height="26" Margin="0,0,4,0"
                                 ToolTip="English text"
                                 AutomationProperties.Name="English text"/>
                        <TextBox Text="{Binding NewWordFrequency, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}"
                                 Width="70" Height="26" Margin="0,0,4,0"
                                 ToolTip="English text"
                                 AutomationProperties.Name="English text"/>
                        <Button Content="+ English text"
                                Command="{Binding AddWordCommand}"
                                Style="{StaticResource AccentBtn}"
                                AutomationProperties.Name="English text"/>
                    </WrapPanel>

                    <!-- English text -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="English text"
                                Command="{Binding RemoveSelectedCommand}"
                                Style="{StaticResource DarkBtn}"
                                ToolTip="English text"/>
                        <Button Content="English text"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource DangerBtn}"
                                ToolTip="English text"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- English text -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding FilteredWords}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource SettingsHighlight}"
                      Background="{DynamicResource SettingsBg}"
                      Foreground="{DynamicResource SettingsFg}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SettingsHighlight}"
                      BorderBrush="{DynamicResource SettingsHighlight}"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      FontSize="12"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="36"/>
                    <DataGridTextColumn Header="English text"
                                        Binding="{Binding Word}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="English text" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Frequency, UpdateSourceTrigger=LostFocus}"
                                         Background="Transparent"
                                         Foreground="{DynamicResource SettingsFg}"
                                         BorderThickness="0"
                                         HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕"
                                        Command="{Binding DataContext.RemoveOneCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        Foreground="{DynamicResource SettingsFgHint}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        FontSize="11"
                                        ToolTip="English text"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ── English text ── -->
        <Grid Grid.Row="2" Visibility="{Binding BigramTabVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- English text -->
            <Border Grid.Row="0" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="English text"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsPrimaryTabActive, Mode=TwoWay}"
                                 Margin="0,0,12,0" Padding="6,3"
                                 GroupName="BigramDictTab"/>
                    <RadioButton Content="English"
                                 Foreground="{DynamicResource SettingsFg}"
                                 IsChecked="{Binding IsEnglishTabActive, Mode=TwoWay}"
                                 Padding="6,3"
                                 GroupName="BigramDictTab"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource FluentCardBorderStyle}" Margin="0,0,0,8" Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramPrev, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="140" Height="26" Margin="0,0,8,0"
                             ToolTip="English text"
                             AutomationProperties.Name="English text"/>
                    <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramNext, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="140" Height="26" Margin="0,0,8,0"
                             ToolTip="English text"
                             AutomationProperties.Name="English text"/>
                    <TextBlock Text="English text" Foreground="{DynamicResource SettingsFgSub}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding NewBigramCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"
                             Width="70" Height="26" Margin="0,0,8,0"
                             ToolTip="English text"
                             AutomationProperties.Name="English text"/>
                    <Button Content="+ English text"
                            Command="{Binding AddBigramPairCommand}"
                            Style="{StaticResource AccentBtn}"
                            AutomationProperties.Name="English text"/>
                </StackPanel>
            </Border>

            <!-- English text -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding BigramRows}"
                      SelectedItem="{Binding SelectedBigramRow}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource SettingsHighlight}"
                      Background="{DynamicResource SettingsBg}"
                      Foreground="{DynamicResource SettingsFg}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource SettingsHighlight}"
                      BorderBrush="{DynamicResource SettingsHighlight}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      FontSize="12"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="English text" Binding="{Binding Prev}" Width="*"/>
                    <DataGridTextColumn Header="English text" Binding="{Binding Next}" Width="*"/>
                    <DataGridTextColumn Header="English text" Binding="{Binding Count}" Width="80"/>
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="English text"
                                        Command="{Binding DataContext.RemoveBigramPairCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DarkBtn}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- English text -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
                <Button Content="English text"
                        Command="{Binding RemoveBigramsByPrevCommand}"
                        CommandParameter="{Binding SelectedBigramRow}"
                        Style="{StaticResource DarkBtn}"
                        AutomationProperties.Name="English text"/>
                <Button Content="English text"
                        Command="{Binding ClearAllBigramsCommand}"
                        Style="{StaticResource DangerBtn}"
                        AutomationProperties.Name="English text"/>
            </StackPanel>
        </Grid>

        <!-- ── English text ── -->
        <Border Grid.Row="3" Style="{StaticResource FluentCardBorderStyle}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource SettingsFgSub}" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="English text"
                        Click="CloseButton_Click"
                        Style="{StaticResource DarkBtn}"
                        AutomationProperties.Name="English text"/>
            </Grid>
        </Border>
    </Grid>
</Window>

