<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:LArtKey.Controls"
                    xmlns:themes="clr-namespace:LArtKey.Themes">

    <themes:ProgressToOffsetConverter x:Key="ProgressToOffsetConverter"/>
    
    <Style TargetType="{x:Type controls:KeyButton}">
        <Setter Property="Background"       Value="{DynamicResource KeyBg}"/>
        <Setter Property="Foreground"       Value="{DynamicResource KeyFg}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource KeyBorder}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="FontFamily"       Value="{DynamicResource KeyFont}"/>
        <Setter Property="FontSize"         Value="{DynamicResource ScaledKeyFontSize}"/>
        <Setter Property="Padding"          Value="2"/>
        <Setter Property="Margin"           Value="2"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Focusable"        Value="False"/>
        <Setter Property="IsTabStop"        Value="False"/>
        <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}"/>
        <Setter Property="AutomationProperties.HelpText" Value="{Binding AccessibleHelp}"/>
        <Setter Property="AutomationProperties.AutomationId" Value="{Binding AutomationId}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyButton}">
                    <Grid ClipToBounds="False">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource KeyRadius}"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale"/>
                            </Border.RenderTransform>
                            <Grid>
                                <!-- text -->
                                <TextBlock x:Name="SubLabelText"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                          Path=SubLabel}"
                                           FontSize="{DynamicResource ScaledSubLabelFontSize}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Margin="0,2,4,0"
                                           Opacity="0.65"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                                <TextBlock x:Name="MainLabel"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=DisplayLabel}"
                                           FontSize="{TemplateBinding FontSize}"
                                           Margin="4,0,4,0"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                                <!-- L2: Locked text) -->
                                <TextBlock x:Name="LockIcon"
                                           Text="🔒"
                                           FontSize="9"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,4,2"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                                <!-- L2: Sticky text "S" text -->
                                <TextBlock x:Name="StickyBadge"
                                           Text="S"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,4,2"
                                           Foreground="{DynamicResource KeyFgSticky}"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                                <!-- Fn layer. -->
                                <TextBlock x:Name="FunctionBadge"
                                           Text="Fn"
                                           FontSize="8"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,4,2"
                                           Foreground="{DynamicResource KeyFgAccent}"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                                <TextBlock x:Name="FunctionLockIcon"
                                           Text="🔒"
                                           FontSize="9"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,4,2"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           AutomationProperties.Name=""/>
                            </Grid>
                        </Border>

                        <!-- L2: Sticky text) -->
                        <Rectangle x:Name="StickyDashBorder"
                                   Stroke="{DynamicResource KeyFgSticky}"
                                   StrokeDashArray="2,2"
                                   StrokeThickness="1.5"
                                   Fill="Transparent"
                                   RadiusX="8"
                                   RadiusY="8"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False"
                                   SnapsToDevicePixels="True"/>
                        <Rectangle x:Name="FunctionDashBorder"
                                   Stroke="{DynamicResource KeyBorderAccent}"
                                   StrokeDashArray="3,2"
                                   StrokeThickness="1.5"
                                   Fill="Transparent"
                                   RadiusX="8"
                                   RadiusY="8"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False"
                                   SnapsToDevicePixels="True"/>

                        <!-- T-5.2: text -->
                        <Ellipse x:Name="DwellRing"
                                 Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                 Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                 Margin="0"
                                 Stroke="{DynamicResource KeyFgSticky}"
                                 StrokeThickness="4"
                                 Fill="Transparent"
                                 StrokeDashArray="100"
                                 StrokeDashOffset="{Binding DwellProgress,
                                     RelativeSource={RelativeSource TemplatedParent},
                                     Converter={StaticResource ProgressToOffsetConverter}}"
                                 Opacity="{Binding DwellProgress,
                                     RelativeSource={RelativeSource TemplatedParent}}"
                                 IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- L2: Hover — text -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgHover}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="controls:KeyButton.ReducedMotionEnabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.04" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.04" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <!-- L2: Pressed — text -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgPressed}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True"/>
                                <Condition Property="controls:KeyButton.ReducedMotionEnabled" Value="False"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.93" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.93" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.0" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="Scale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.0" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#FF555555"/>
                        </Trigger>

                        <!-- L1: text -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="Root" Property="BorderThickness"
                                    Value="3"/>
                        </Trigger>

                        <Trigger Property="controls:KeyButton.IsA11yFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="Root" Property="BorderThickness"
                                    Value="3"/>
                        </Trigger>

                        <!-- L2/T-4.7: Sticky text) — text -->
                        <!-- text. -->
                        <DataTrigger Binding="{Binding HasSoftAccentStyle}" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgAccent}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource KeyFgAccent}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource KeyBorderAccent}"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasSoftAccentStyle}" Value="True"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgAccentHover}"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasSoftAccentStyle}" Value="True"/>
                                <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgAccentPressed}"/>
                        </MultiDataTrigger>
                        <Trigger Property="controls:KeyButton.IsSticky" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgSticky}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource KeyFgSticky}"/>
                            <Setter TargetName="StickyDashBorder" Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="StickyBadge" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <!-- L2/T-4.7: Locked text) — text -->
                        <Trigger Property="controls:KeyButton.IsLocked" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgSticky}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource KeyFgSticky}"/>
                            <Setter TargetName="LockIcon" Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="StickyDashBorder" Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="StickyBadge" Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="controls:KeyButton.IsFunctionOneShot" Value="True"/>
                                <Condition Property="controls:KeyButton.HasFunctionLayerAccent" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource KeyBorderAccent}"/>
                            <Setter TargetName="FunctionDashBorder" Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="FunctionBadge" Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="controls:KeyButton.IsFunctionLocked" Value="True"/>
                                <Condition Property="controls:KeyButton.HasFunctionLayerAccent" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource KeyBgAccent}"/>
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource KeyBorderAccent}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource KeyFgAccent}"/>
                            <Setter TargetName="FunctionDashBorder" Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="FunctionBadge" Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="FunctionLockIcon" Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <!-- 07: text -->
                        <DataTrigger Binding="{Binding Slot.IsInputModeToggle, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{DynamicResource AccentBrush}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
