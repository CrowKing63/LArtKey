<UserControl x:Class="LArtKey.Controls.NumericAdjuster"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- text. -->
        <Style x:Key="AdjustButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{Binding TextBoxBorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{Binding ButtonBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Foreground" Value="{Binding ButtonForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.72"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AdjustValueTextBoxStyle" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Background" Value="{Binding TextBoxBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Foreground" Value="{Binding TextBoxForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="BorderBrush" Value="{Binding TextBoxBorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="DecreaseButton"
                Grid.Column="0"
                Content="-"
                Style="{StaticResource AdjustButtonStyle}"/>

        <TextBox x:Name="ValueTextBox"
                 Grid.Column="1"
                 Style="{StaticResource AdjustValueTextBoxStyle}"/>

        <Button x:Name="IncreaseButton"
                Grid.Column="2"
                Content="+"
                Style="{StaticResource AdjustButtonStyle}"/>
    </Grid>
</UserControl>
